# Dashboard environment variables (Vite).
#
# Copy this file to `.env` (or `.env.local`) and adjust the values for your
# environment. Vite only exposes variables prefixed with `VITE_` to the
# client bundle, and they are inlined at BUILD time - rebuild after changing.

# Base URL of the GAME backend API (including the /api/v1 prefix).
# Falls back to http://localhost:8000/api/v1 when unset.
VITE_GAME_API_URL=http://localhost:8000/api/v1

# Keycloak SSO configuration.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=game
VITE_KEYCLOAK_CLIENT_ID=game-dashboard

# Client id used when minting API keys for the backend service client.
# Defaults to VITE_KEYCLOAK_CLIENT_ID when unset.
VITE_KEYCLOAK_API_CLIENT_ID=game-backend
