{
  "title": "DSL Overview",
  "uid": "game-dsl-overview",
  "tags": ["game", "dsl", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "editable": true,
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "realm",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"query": "label_values(dsl_execution_duration_seconds_count, realm)", "refId": "Prometheus-realm"},
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "DSL p99 latency by realm",
      "description": "99th percentile of DslStrategy.calculate_points wall-clock duration. SLO: 250ms (the alert in dsl-rules.yml fires above this).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.15},
              {"color": "red", "value": 0.25}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum by (le, realm) (rate(dsl_execution_duration_seconds_bucket{status=\"ok\", realm=~\"$realm\"}[5m])))",
          "legendFormat": "{{realm}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "DSL error rate by code",
      "description": "Errors per second grouped by error code. Codes are defined in app/core/exceptions.py (DSL_*).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (realm, code) (rate(dsl_execution_errors_total{realm=~\"$realm\"}[5m]))",
          "legendFormat": "{{realm}} / {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DSL executions per minute",
      "description": "Total DslStrategy.calculate_points calls per minute, broken down by strategy_type (DSL_FULL vs DSL_EXTEND).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "sum"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (realm, strategy_type) (rate(dsl_execution_duration_seconds_count{realm=~\"$realm\"}[1m])) * 60",
          "legendFormat": "{{realm}} / {{strategy_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DSL AST nodes per minute",
      "description": "Total interpreter nodes visited per minute. Spikes here usually mean a designer added a rule that fans out widely.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (realm) (rate(dsl_execution_nodes_total{realm=~\"$realm\"}[1m])) * 60",
          "legendFormat": "{{realm}}",
          "refId": "A"
        }
      ]
    }
  ]
}
