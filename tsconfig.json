{
  "compilerOptions": {
    /* Language and Environment */
    "target": "es2016",
    "module": "commonjs",
    "lib": ["es2016"],

    /* Modules */
    "rootDir": "./src",
    "moduleResolution": "node",
    "baseUrl": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "skipLibCheck": true /* Skip type checking of declaration files. */,
    "noImplicitUseStrict": false /* Do not automatically add 'use strict'. */,
    "noEmitOnError": true /* Do not emit outputs if there are compilation errors. */,
    "preserveWatchOutput": false /* Do not clear the console output when recompiling in watch mode. */,
    "removeComments": false /* Remove comments in the output files. */,
    "noErrorTruncation": true /* Do not truncate error messages. */,
    "noImplicitAny": true /* Enable error reporting for expressions and declarations with an implicit 'any' type. */,
    "strictNullChecks": true /* Enable strict null checks. */,
    "strictBindCallApply": true /* Ensure that the arguments for 'bind', 'call', and 'apply' match the original function. */,
    "strictFunctionTypes": true /* Ensure that function parameter and return value types are subtype-compatible. */,
    "strictPropertyInitialization": true /* Ensure that class properties are initialized in the constructor. */,
    "noImplicitThis": true /* Enable error reporting when 'this' is of type 'any'. */,
    "alwaysStrict": true /* Ensure that 'use strict' is always emitted. */,
    "strict": true /* Enable all strict type-checking options. */,
    "useUnknownInCatchVariables": true /* Use the 'unknown' type instead of 'any' for catch clause variables. */,
    "exactOptionalPropertyTypes": true /* Interpret optional property types as written, rather than adding 'undefined'. */,
    "noImplicitReturns": true /* Report error in functions that do not return a value on all code paths. */,
    "noFallthroughCasesInSwitch": true /* Report error for fall-through cases in switch statements. */,
    "noUncheckedIndexedAccess": true /* Add 'undefined' to a type when accessed using an index. */,
    "noImplicitOverride": true /* Ensure that overriding members in derived classes are marked with an 'override' modifier. */,
    "noPropertyAccessFromIndexSignature": true /* Require the use of indexed accessors for keys declared using an indexed type. */
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
